    {
      "parameters": {
        "jsCode": "const b = ($json.body && Object.keys($json.body).length) ? $json.body : $json;\n\n// Usamos tags HTML para formatar o e-mail\nconst htmlLinhas = [\n  `Olá,`,\n  `<br><br>`,\n  `Recebemos um novo envio do formulário de parcerias. Seguem abaixo as informações coletadas para que você possa criar o cadastro posteriormente no sistema.`,\n  `<br><br>`,\n  `<strong>DADOS DO CADASTRO</strong>`,\n  `Tipo de parceria: ${b.tipoParceria || ''}`,\n  `Nome completo: ${b.nome || ''}`,\n  `CPF: ${b.cpf || ''}`,\n  `Data de nascimento: ${b.nascimento || ''}`,\n  `E-mail: ${b.email || ''}`,\n  `WhatsApp: ${b.whatsapp || ''}`,\n  `Cidade/UF: ${b.cidade || ''} / ${b.uf || ''}`,\n  `<br><br>`,\n  `<strong>DADOS DA EMPRESA (se aplicável)</strong>`,\n  `CNPJ: ${b.cnpj || ''}`,\n  `Razão social: ${b.razao || ''}`,\n  `<br><br>`,\n  `<strong>PERFIL / OPERAÇÃO</strong>`,\n  `Já atua na área: ${b.jaAtua || ''}`,\n  `Já foi AGR: ${b.jaFoiAgr || ''}`,\n  `Realiza vendas: ${b.vendas || ''}`,\n  `Área de atuação: ${b.area || ''}`,\n  `Possui CNPJ: ${b.cnpjTem || ''}`,\n  `Regime tributário: ${b.regime || ''}`,\n  `Modelo: ${b.modelo || ''}`,\n  `Disponibilidade: ${b.disponibilidade || ''}`,\n  `Captação: ${b.captacao || ''}`,\n  `Volume estimado: ${b.volume || ''}`,\n  `Observações: ${b.observacoes || ''}`,\n  `<br><br>`,\n  `<strong>CONFORMIDADE E ORIGEM</strong>`,\n  `LGPD aceito: ${b.lgpd ? 'SIM' : 'NÃO'}`,\n  `Origem: ${b.origem || ''}`,\n  `Timestamp do formulário: ${b.timestamp || ''}`,\n  `<br><br>`,\n  `<strong>Ações sugeridas</strong><br>1) Criar/atualizar o cadastro no sistema com os dados acima.<br>2) Retornar contato para o lead se necessário.`,\n  `<br><br>`,\n  `—<br>Mensagem automática (formulário de parcerias)`\n];\n\n// Juntamos as linhas com a tag de quebra de linha do HTML\nconst htmlBody = htmlLinhas.join('<br>');\n\n// Para o WhatsApp, mantemos o texto simples sem HTML\nconst plainText = htmlBody.replace(/<br>/g, '\\n').replace(/<strong>/g, '').replace(/<\\/strong>/g, '');\n\nreturn [{\n  json: {\n    subject: `Novo cadastro parceria - ${b.nome || 'Sem nome'}`,\n    emailHtmlBody: htmlBody, // Corpo do e-mail em HTML\n    whatsappText: plainText, // Texto simples para o WhatsApp\n  }\n}];"
      },
