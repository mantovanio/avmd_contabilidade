    {
      "parameters": {
        "jsCode": "const saida = $input.all().map(item => {\n  const json = { ...item.json };\n\n  // --- 1. FUNÇÃO: TRATAR DATA ---\n  function formatarDataBR(valor) {\n    if (!valor) return 'em breve';\n    let s = String(valor).trim().split(' ')[0];\n    if (/^\\d{4}-\\d{2}-\\d{2}$/.test(s)) {\n      const [yyyy, mm, dd] = s.split('-');\n      return `${dd}/${mm}/${yyyy}`;\n    }\n    return s;\n  }\n\n  const dataExp = formatarDataBR(json.Expiração || json['Data de Vencimento'] || json.VencimentoISO);\n\n  // --- 2. LÓGICA DE DOCUMENTO (TAMANHO REAL + PONTUAÇÃO) ---\n  const docLimpo = String(json['Documento Registrado'] || json.Documento || json.CNPJ || '').replace(/\\D/g, '');\n  let docExibir = \"N/A\";\n  let rotuloDoc = \"Documento\";\n\n  if (docLimpo.length === 11) {\n    rotuloDoc = \"CPF\";\n    // Padrão: 000.000.000-00 (11 dígitos)\n    // Vamos ocultar do 4º ao 7º dígito\n    docExibir = `${docLimpo.slice(0, 3)}.XXX.X${docLimpo.slice(7, 9)}-${docLimpo.slice(9, 11)}`;\n    // Resultado exemplo: 195.XXX.X66-34 (Total 11 números/X)\n  } \n  else if (docLimpo.length === 14) {\n    rotuloDoc = \"CNPJ\";\n    // Padrão: 00.000.000/0000-00 (14 dígitos)\n    // Vamos ocultar do 5º ao 8º dígito (os 4 que vêm antes da barra)\n    docExibir = `${docLimpo.slice(0, 2)}.${docLimpo.slice(2, 5)}.XXX/${docLimpo.slice(8, 12)}-${docLimpo.slice(12, 14)}`;\n    // Resultado exemplo: 49.73X.XXX/0001-19 (Total 14 números/X)\n  }\n\n  // --- 3. AGENTE E NOME ---\n  const nomeAgenteRaw = json['Nome Agente'] || json['Vendedor/Indicação'] || 'Alexandre';\n  const nomeAgente = String(nomeAgenteRaw).split(' ')[0].toUpperCase();\n  const nomeRef = json['Nome/Razão Social'] || json.Nome || 'CLIENTE';\n\n  // --- 4. MONTAGEM DA MENSAGEM ---\n  json.whatsappMessage = `👋 Olá, *${nomeRef}*! Tudo bem?\n\n📅 Passando para te avisar que seu certificado digital vai expirar em *${dataExp}*.\n\nPara *garantir a continuidade das suas operações*, recomendamos a renovação imediata. ✅\n\n---\n*Detalhes do seu certificado:*\n📄 *Produto:* ${json.Certificado || json.ProdutoPadronizado || 'Certificado Digital'}\n📦 *Pedido/Ticket:* ${json['Pedido/Ticket'] || json.Protocolo || 'N/A'}\n📅 *Data de expiração:* ${dataExp}\n🔢 *${rotuloDoc}:* ${docExibir}\n---\n\n👉 Fale conosco para iniciar o processo de renovação. Conte com a CertiID para manter seu certificado digital sempre em dia!\n\nAgente de Registro - *${nomeAgente}* 🔒✨`;\n\n  return { json };\n});\n\nreturn saida;\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        288,
        -416
      ],
      "id": "3876e980-8fd4-4712-9683-9587306e615a",
      "name": "Aviso_renovação"
    },
    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\n\n// 1. CAPTURA O PARCEIRO E O PRIMEIRO NOME\nconst parceiroCompleto = item.Parceiro || \"\";\nconst primeiroNomeParceiro = parceiroCompleto.split(' ')[0] || \"Parceiro\";\n\n// 2. DEFINE O TELEFONE DO AGENTE (ROTEAMENTO)\nlet telefoneDestino = \"5511983500019\"; // Número da Matriz\nif (parceiroCompleto.toUpperCase().includes(\"ISABELLA\")) {\n    telefoneDestino = \"553197620119\"; // Número da Isabella\n}\n\n// 3. MONTAGEM DA MENSAGEM (SEM OCULTAR DADOS)\nconst mensagem = `Olá, *${primeiroNomeParceiro}*! Dados de renovação para seu cliente:\n\n*Dados*\n🏢 *Cliente:* ${item.Cliente || item['Nome/Razão Social'] || 'Não informado'}\n🔢 *Documento:* ${item.Pedido || item['Documento Registrado'] || 'Não informado'}\n📞 *Telefone:* ${item.Telefone || 'Não informado'}\n📧 *E-mail:* ${item.Email || item['E-mail'] || 'Não informado'}\n📦 *Pedido/Protocolo:* ${item.Pedido || item.Protocolo || 'N/A'}\n📅 *Vencimento:* ${item['Expiração'] || 'Não informado'}\n📄 *Produto:* ${item.Certificado || 'Certificado Digital'}\n\n*Ação:* Favor entrar em contato para finalizar o processo! 📈`;\n\n// 4. SAÍDA DOS DADOS PARA OS PRÓXIMOS NÓS\nreturn [{\n    json: {\n        ...item,\n        lembreteInterno: mensagem,\n        telefoneAgente: telefoneDestino\n    }\n}];\n"
      },
