      "parameters": {
        "jsCode": "const saida = $input.all().map(item => {\n  const original = { ...item.json };\n\n  // --- 1. FUNÇÃO: NORMALIZAR DATAS (IGNORA HORA E CONVERTE PARA ISO) ---\n  function toISO(dateAny) {\n    if (!dateAny) return '';\n    // Pega apenas a parte da data antes do espaço (remove HH:mm:ss)\n    let s = String(dateAny).trim().split(' ')[0]; \n    \n    // Caso DD/MM/YYYY\n    if (s.includes('/')) {\n      const partes = s.split('/');\n      if (partes.length === 3) {\n        // Retorna YYYY-MM-DD\n        return `${partes[2]}-${partes[1]}-${partes[0]}`;\n      }\n    }\n    // Caso YYYY-MM-DD (já é ISO)\n    if (/^\\d{4}-\\d{2}-\\d{2}$/.test(s)) {\n      return s;\n    }\n    return '';\n  }\n\n  // --- 2. FUNÇÃO: NORMALIZAR TELEFONE (PADRÃO WHATSAPP 55) ---\n  function normalizarTelefone(tel) {\n    if (!tel) return '';\n    let digits = String(tel).replace(/\\D/g, '');\n    // Se tiver 10 ou 11 dígitos (DDD + Número), adiciona o 55\n    if (digits.length === 10 || digits.length === 11) {\n      return '55' + digits;\n    }\n    // Se já tiver 12 ou mais e começar com 55, mantém\n    if (digits.length >= 12 && digits.startsWith('55')) {\n      return digits;\n    }\n    return '';\n  }\n\n  // --- 3. CONSOLIDAÇÃO DO DOCUMENTO (SEM DUPLICIDADE) ---\n  const valorDoc = original[\"Documento registrado\"] || \n                   original[\"documento registrado\"] || \n                   original[\"Documento Registrado\"] || \n                   original.documento || \n                   original.Documento || '';\n\n  let docLimpo = String(valorDoc).replace(/\\D/g, '');\n  if (docLimpo.length > 14) docLimpo = '';\n\n  // Deleta as variações para limpar a visualização na Mesa (JSON)\n  delete original[\"Documento registrado\"];\n  delete original[\"documento registrado\"];\n  delete original.documento;\n  delete original.Documento;\n\n  // --- 4. CÁLCULO DE DIAS RESTANTES (RETORNA NÚMERO INTEIRO) ---\n  const dataVenc = toISO(original[\"Data de Vencimento\"] || original.Expiração || original.Vencimento);\n  let diasRestantes = null;\n  \n  if (dataVenc) {\n    try {\n      // Ajuste para 00:00:00 para garantir cálculo de dias exatos\n      const d1 = new Date(dataVenc + 'T00:00:00'); \n      const d2 = new Date();\n      d2.setHours(0, 0, 0, 0);\n      \n      const diff = d1.getTime() - d2.getTime();\n      // Retorna número inteiro (ex: 1, 5, 10, -58)\n      diasRestantes = Math.round(diff / (1000 * 60 * 60 * 24));\n    } catch (e) {\n      diasRestantes = null;\n    }\n  }\n\n  // --- 5. RESULTADO FINAL ---\n  return {\n    json: {\n      ...original,\n      \"Documento Registrado\": docLimpo,\n      \"Telefone\": normalizarTelefone(original.Telefone),\n      \"VencimentoISO\": dataVenc,\n      \"DiasParaVencimento\": diasRestantes, // Sai como Number\n      \"UltimoProcessamento\": new Date().toISOString()\n    }\n  };\n});\n\n// Filtra apenas quem tem telefone válido e ignora quem já venceu (negativos)\nreturn saida.filter(item => {\n  const temTelefone = item.json.Telefone && item.json.Telefone.length >= 12;\n  const naoVencido = item.json.DiasParaVencimento !== null && item.json.DiasParaVencimento >= 0;\n  return temTelefone && naoVencido;\n});\n"
      },
